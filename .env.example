# HomeGentic Environment Variables
DFX_NETWORK=local

# Canister IDs (populated by dfx deploy)
AUTH_CANISTER_ID=
PROPERTY_CANISTER_ID=
JOB_CANISTER_ID=
CONTRACTOR_CANISTER_ID=
QUOTE_CANISTER_ID=
PRICE_CANISTER_ID=
PAYMENT_CANISTER_ID=
PHOTO_CANISTER_ID=
MONITORING_CANISTER_ID=
FRONTEND_CANISTER_ID=
AI_PROXY_CANISTER_ID=

# ICP Network
ICP_HOST=http://localhost:4943

# Voice Agent (agents/voice)
ANTHROPIC_API_KEY=
VOICE_AGENT_PORT=3001
FRONTEND_ORIGIN=http://localhost:3000
# Shared secret checked on all /api/ routes. Required in production.
VOICE_AGENT_API_KEY=

# Email (Resend — resend.com, free tier: 3,000/month, 100/day)
# These are passed to the ai_proxy canister at deploy time via scripts/deploy.sh
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@homegentic.app

# OpenPermit API key (openpermit.org — for non-Volusia cities)
OPEN_PERMIT_API_KEY=

# Rentcast API key — auto-fills year built & sq ft on property registration
# Free tier: 50 req/month — https://app.rentcast.io/app/api-access
VITE_RENTCAST_API_KEY=

# Frontend — point at the voice proxy
VITE_VOICE_AGENT_URL=http://localhost:3001
# Must match VOICE_AGENT_API_KEY above so the frontend can authenticate
VITE_VOICE_AGENT_API_KEY=
