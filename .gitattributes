# Force LF line endings for files that must be executable on Linux/macOS.
# Without this, Windows git (core.autocrlf=true) commits CRLF into shell
# scripts, causing bash to fail with "set: pipefail\r: invalid option name"
# when run on Linux.

# Shell scripts — always LF
*.sh        text eol=lf

# Makefiles — always LF (make is whitespace-sensitive; CRLF breaks recipes)
Makefile    text eol=lf
makefile    text eol=lf
GNUmakefile text eol=lf

# Motoko source
*.mo        text eol=lf

# All other text files — normalise to LF in repo, checkout as-is on Windows
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.env*      text eol=lf

# Binaries — no line-ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.wasm      binary
*.pdf       binary
