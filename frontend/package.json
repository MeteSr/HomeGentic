{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/gen-ic-assets.mjs && npm run check:security",
    "build:ssg": "npm run build && node scripts/prerender.mjs && npm run gen:sitemap",
    "gen:sitemap": "node scripts/gen-sitemap.mjs",
    "check:security": "node scripts/security-checks.mjs",
    "preview": "vite preview",
    "test": "vitest run --exclude 'src/__tests__/perf/**'",
    "test:unit": "vitest run --exclude 'src/__tests__/perf/**' --exclude 'src/__tests__/integration/**'",
    "test:unit:watch": "vitest --exclude 'src/__tests__/perf/**' --exclude 'src/__tests__/integration/**'",
    "test:unit:coverage": "vitest run --coverage --exclude 'src/__tests__/perf/**' --exclude 'src/__tests__/integration/**'",
    "test:integration": "vitest run src/__tests__/integration",
    "test:perf": "vitest run src/__tests__/perf"
  },
  "dependencies": {
    "@dfinity/vetkeys": "0.4.0",
    "@icp-sdk/auth": "^5.0.0",
    "@icp-sdk/core": "^5.2.1",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.1.0",
    "lucide-react": "^1.7.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^7.13.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.0",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vitest": "^4.0.0"
  }
}
