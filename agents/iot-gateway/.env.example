# ── HomeFax IoT Gateway ──────────────────────────────────────────────────────

# Port the gateway listens on (default: 3002)
IOT_GATEWAY_PORT=3002

# ICP replica host
#   Local dev:  http://localhost:4943
#   Mainnet:    https://ic0.app
ICP_HOST=http://localhost:4943

# Sensor canister ID (from dfx deploy output / .env file after deploy)
SENSOR_CANISTER_ID=

# 32-byte hex Ed25519 seed for the gateway's service identity.
# This principal must be added to the sensor canister via:
#   dfx canister call sensor addGateway '(principal "...")'
# Leave blank during local dev to use an ephemeral identity (add it to canister each restart).
GATEWAY_IDENTITY_SEED=

# ── Webhook secrets ───────────────────────────────────────────────────────────
# Leave blank to skip signature validation (local dev only).

# Google Nest SDM — match the token you configure in the Pub/Sub push subscription
NEST_WEBHOOK_SECRET=

# Ecobee — HMAC-SHA256 signing secret from the Ecobee Developer Portal
ECOBEE_WEBHOOK_SECRET=

# Moen Flo — HMAC-SHA256 signing secret from the Moen Flo Partner Portal
MOEN_FLO_WEBHOOK_SECRET=
