# DFX artifacts (kept during icp-cli transition)
.dfx/
canister_ids.json

# icp-cli cache (ephemeral local state — do NOT gitignore .icp/data/ which holds mainnet canister IDs)
.icp/cache/

# Downloaded wasm binaries (fetched by deploy.sh, not committed)
.cache/

# Node
node_modules/
src/frontend/node_modules/

# Build output
src/frontend/dist/
dist/
frontend/dist/
frontend/coverage/
frontend/dist-test-sitemap/

# Test artefacts
test-results/
frontend/test-results/
playwright-report/

# Environment
.env
.env.local

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Claude Code local settings (memory, project config, conversation state).
# Use .claude/* rather than .claude/ so negation rules for children work.
.claude/*
# Worktrees created by Claude Code's isolation mode are nested git repos.
# Gitlinks (mode 160000) bypass parent .gitignore, so we commit a sentinel
# .gitignore inside worktrees/ that makes git ignore every subdirectory there.
!.claude/worktrees/
.claude/worktrees/*
!.claude/worktrees/.gitignore
